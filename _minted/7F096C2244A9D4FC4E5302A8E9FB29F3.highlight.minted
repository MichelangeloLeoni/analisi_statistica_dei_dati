    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{build\PYGZus{}belt}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{method}\PYG{p}{,} \PYG{n}{ordering\PYGZus{}type}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZsq{}\PYGZsq{}\PYGZsq{}}
\PYG{l+s+sd}{        Construct the full Neyman confidence belt.}

\PYG{l+s+sd}{        For each value of mu in the grid, compute the corresponding}
\PYG{l+s+sd}{        acceptance region over the observable space.}

\PYG{l+s+sd}{        Output:}
\PYG{l+s+sd}{            mask\PYGZus{}list : list of boolean arrays}
\PYG{l+s+sd}{                Each element is the acceptance region for a given mu.}
\PYG{l+s+sd}{        \PYGZsq{}\PYGZsq{}\PYGZsq{}}

        \PYG{n}{mask\PYGZus{}list} \PYG{o}{=} \PYG{p}{[]}

        \PYG{c+c1}{\PYGZsh{} Loop over all parameter values}
        \PYG{k}{for} \PYG{n}{mu} \PYG{o+ow}{in} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{mu\PYGZus{}grid}\PYG{p}{:}
            \PYG{n}{mask}\PYG{p}{,} \PYG{n}{\PYGZus{}} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{get\PYGZus{}slice}\PYG{p}{(}\PYG{n}{mu}\PYG{p}{,} \PYG{n}{method}\PYG{p}{,} \PYG{n}{ordering\PYGZus{}type}\PYG{p}{)}
            \PYG{n}{mask\PYGZus{}list}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{mask}\PYG{p}{)}

        \PYG{k}{return} \PYG{n}{mask\PYGZus{}list}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{find\PYGZus{}interval}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x\PYGZus{}obs}\PYG{p}{,} \PYG{n}{method}\PYG{p}{,} \PYG{n}{ordering\PYGZus{}type}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZsq{}\PYGZsq{}\PYGZsq{}}
\PYG{l+s+sd}{        Extract confidence interval for a given observed value.}

\PYG{l+s+sd}{        The interval is obtained by inverting the Neyman construction:}
\PYG{l+s+sd}{        selecting all mu values whose acceptance region includes x\PYGZus{}obs.}

\PYG{l+s+sd}{        Parameters:}
\PYG{l+s+sd}{            x\PYGZus{}obs : float or int}
\PYG{l+s+sd}{                Observed data point.}
\PYG{l+s+sd}{            method : str}
\PYG{l+s+sd}{                Ordering method used in construction.}
\PYG{l+s+sd}{            ordering\PYGZus{}type : str}
\PYG{l+s+sd}{                Type of ordering (\PYGZdq{}p\PYGZdq{}, \PYGZdq{}upper\PYGZdq{}, \PYGZdq{}lower\PYGZdq{}).}

\PYG{l+s+sd}{        Output:}
\PYG{l+s+sd}{            interval : tuple (mu\PYGZus{}min, mu\PYGZus{}max)}
\PYG{l+s+sd}{                Confidence interval for the parameter.}
\PYG{l+s+sd}{                Returns (nan, nan) if no mu is accepted.}
\PYG{l+s+sd}{        \PYGZsq{}\PYGZsq{}\PYGZsq{}}

        \PYG{n}{accepted\PYGZus{}mu} \PYG{o}{=} \PYG{p}{[]}

        \PYG{c+c1}{\PYGZsh{} Build full Neyman belt}
        \PYG{n}{mask\PYGZus{}list} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{build\PYGZus{}belt}\PYG{p}{(}\PYG{n}{method}\PYG{p}{,} \PYG{n}{ordering\PYGZus{}type}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Check which mu values accept the observation}
        \PYG{k}{for} \PYG{n}{mu}\PYG{p}{,} \PYG{n}{mask} \PYG{o+ow}{in} \PYG{n+nb}{zip}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{mu\PYGZus{}grid}\PYG{p}{,} \PYG{n}{mask\PYGZus{}list}\PYG{p}{):}

            \PYG{k}{if} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{discrete}\PYG{p}{:}
                \PYG{c+c1}{\PYGZsh{} Discrete case: direct indexing}
                \PYG{k}{if} \PYG{n}{x\PYGZus{}obs} \PYG{o}{\PYGZlt{}} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{mask}\PYG{p}{)} \PYG{o+ow}{and} \PYG{n}{mask}\PYG{p}{[}\PYG{n}{x\PYGZus{}obs}\PYG{p}{]:}
                    \PYG{n}{accepted\PYGZus{}mu}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{mu}\PYG{p}{)}
            \PYG{k}{else}\PYG{p}{:}
                \PYG{c+c1}{\PYGZsh{} Continuous case: map observation to grid index}
                \PYG{n}{idx} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{searchsorted}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{x\PYGZus{}range}\PYG{p}{,} \PYG{n}{x\PYGZus{}obs}\PYG{p}{)}
                \PYG{k}{if} \PYG{n}{idx} \PYG{o}{\PYGZlt{}} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{mask}\PYG{p}{)} \PYG{o+ow}{and} \PYG{n}{mask}\PYG{p}{[}\PYG{n}{idx}\PYG{p}{]:}
                    \PYG{n}{accepted\PYGZus{}mu}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{mu}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} No accepted values \PYGZhy{}\PYGZgt{} empty confidence interval}
        \PYG{k}{if} \PYG{o+ow}{not} \PYG{n}{accepted\PYGZus{}mu}\PYG{p}{:}
            \PYG{k}{return} \PYG{p}{(}\PYG{n}{np}\PYG{o}{.}\PYG{n}{nan}\PYG{p}{,} \PYG{n}{np}\PYG{o}{.}\PYG{n}{nan}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Return full accepted mu range}
        \PYG{k}{return} \PYG{p}{(}\PYG{n+nb}{min}\PYG{p}{(}\PYG{n}{accepted\PYGZus{}mu}\PYG{p}{),} \PYG{n+nb}{max}\PYG{p}{(}\PYG{n}{accepted\PYGZus{}mu}\PYG{p}{))}
