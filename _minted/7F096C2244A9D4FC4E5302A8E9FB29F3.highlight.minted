            \PYG{p}{)}

        \PYG{k}{else}\PYG{p}{:}
            \PYG{k}{raise} \PYG{n+ne}{ValueError}\PYG{p}{(}\PYG{n}{ordering\PYGZus{}type}\PYG{p}{)}

