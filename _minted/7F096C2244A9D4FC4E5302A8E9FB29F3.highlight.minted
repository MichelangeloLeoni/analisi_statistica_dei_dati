\PYG{+w}{        }\PYG{l+s+sd}{\PYGZsq{}\PYGZsq{}\PYGZsq{}}
\PYG{l+s+sd}{        Initialize the Neyman construction framework.}

\PYG{l+s+sd}{        Parameters:}
\PYG{l+s+sd}{            model : object}
\PYG{l+s+sd}{                Statistical model providing pdf(mu), ratio(mu), cl, and dx.}
\PYG{l+s+sd}{            mu\PYGZus{}grid : array\PYGZhy{}like}
\PYG{l+s+sd}{                Grid of parameter values over which the belt is constructed.}
