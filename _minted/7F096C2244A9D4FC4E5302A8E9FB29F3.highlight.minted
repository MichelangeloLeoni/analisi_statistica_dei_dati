\PYG{l+s+sd}{                Grid of observable values.}
\PYG{l+s+sd}{            discrete : bool}
\PYG{l+s+sd}{                Whether the observable space is discrete or continuous.}
\PYG{l+s+sd}{        \PYGZsq{}\PYGZsq{}\PYGZsq{}}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model} \PYG{o}{=} \PYG{n}{model}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{mu\PYGZus{}grid} \PYG{o}{=} \PYG{n}{mu\PYGZus{}grid}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{x\PYGZus{}range} \PYG{o}{=} \PYG{n}{x\PYGZus{}range}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{discrete} \PYG{o}{=} \PYG{n}{discrete}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{get\PYGZus{}slice}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{mu}\PYG{p}{,} \PYG{n}{method}\PYG{p}{,} \PYG{n}{ordering\PYGZus{}type}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZsq{}\PYGZsq{}\PYGZsq{}}
\PYG{l+s+sd}{        Construct the acceptance region (slice of the Neyman belt)}
\PYG{l+s+sd}{        for a fixed parameter value mu.}

\PYG{l+s+sd}{        Parameters:}
\PYG{l+s+sd}{            mu : float}
\PYG{l+s+sd}{                Parameter value at which the slice is evaluated.}
\PYG{l+s+sd}{            method : str}
\PYG{l+s+sd}{                Method used for ordering (e.g. \PYGZdq{}fc\PYGZdq{} for Feldman\PYGZhy{}Cousins).}
\PYG{l+s+sd}{            ordering\PYGZus{}type : str}
\PYG{l+s+sd}{                Type of ordering (\PYGZdq{}p\PYGZdq{}, \PYGZdq{}upper\PYGZdq{}, \PYGZdq{}lower\PYGZdq{}).}

\PYG{l+s+sd}{        Output:}
\PYG{l+s+sd}{            mask : array\PYGZhy{}like (bool)}
\PYG{l+s+sd}{                Acceptance region mask over x\PYGZus{}range.}
\PYG{l+s+sd}{            thr : float}
\PYG{l+s+sd}{                Threshold value defining the boundary of the region.}
\PYG{l+s+sd}{        \PYGZsq{}\PYGZsq{}\PYGZsq{}}

        \PYG{c+c1}{\PYGZsh{} Compute probability distribution for fixed parameter mu}
        \PYG{n}{pdf} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{pdf}\PYG{p}{(}\PYG{n}{mu}\PYG{p}{)}

        \PYG{k}{if} \PYG{n}{ordering\PYGZus{}type} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}p\PYGZdq{}}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} Define ordering score:}
            \PYG{c+c1}{\PYGZsh{} \PYGZhy{} Feldman\PYGZhy{}Cousins uses likelihood ratio}
            \PYG{c+c1}{\PYGZsh{} \PYGZhy{} Otherwise use the pdf directly}
            \PYG{n}{score} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{ratio}\PYG{p}{(}\PYG{n}{mu}\PYG{p}{)} \PYG{k}{if} \PYG{n}{method} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}fc\PYGZdq{}} \PYG{k}{else} \PYG{n}{pdf}

            \PYG{c+c1}{\PYGZsh{} Build acceptance region using probability ordering}
            \PYG{n}{mask}\PYG{p}{,} \PYG{n}{thr} \PYG{o}{=} \PYG{n}{ordering}\PYG{o}{.}\PYG{n}{score\PYGZus{}ordering}\PYG{p}{(}
                \PYG{n}{score}\PYG{p}{,}
                \PYG{n}{pdf}\PYG{p}{,}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{cl}\PYG{p}{,}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{dx}
            \PYG{p}{)}

        \PYG{k}{elif} \PYG{n}{ordering\PYGZus{}type} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}upper\PYGZdq{}}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} One\PYGZhy{}sided upper confidence construction}
            \PYG{n}{mask}\PYG{p}{,} \PYG{n}{thr} \PYG{o}{=} \PYG{n}{ordering}\PYG{o}{.}\PYG{n}{upper\PYGZus{}ordering}\PYG{p}{(}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{x\PYGZus{}range}\PYG{p}{,}
                \PYG{n}{pdf}\PYG{p}{,}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{cl}\PYG{p}{,}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{dx}
            \PYG{p}{)}

        \PYG{k}{elif} \PYG{n}{ordering\PYGZus{}type} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}lower\PYGZdq{}}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} One\PYGZhy{}sided lower confidence construction}
            \PYG{n}{mask}\PYG{p}{,} \PYG{n}{thr} \PYG{o}{=} \PYG{n}{ordering}\PYG{o}{.}\PYG{n}{lower\PYGZus{}ordering}\PYG{p}{(}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{x\PYGZus{}range}\PYG{p}{,}
                \PYG{n}{pdf}\PYG{p}{,}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{cl}\PYG{p}{,}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{dx}
            \PYG{p}{)}

        \PYG{k}{elif} \PYG{n}{ordering\PYGZus{}type} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}central\PYGZdq{}}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} One\PYGZhy{}sided lower confidence construction}
            \PYG{n}{mask}\PYG{p}{,} \PYG{n}{thr} \PYG{o}{=} \PYG{n}{ordering}\PYG{o}{.}\PYG{n}{central\PYGZus{}ordering}\PYG{p}{(}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{x\PYGZus{}range}\PYG{p}{,}
                \PYG{n}{pdf}\PYG{p}{,}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{model}\PYG{o}{.}\PYG{n}{cl}\PYG{p}{,}
